# Firebase Configuration
# Copie este arquivo para .env e preencha com suas credenciais do Firebase Console
# https://console.firebase.google.com/project/campanini-sabores/settings/general

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=campanini-sabores.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=campanini-sabores
VITE_FIREBASE_STORAGE_BUCKET=campanini-sabores.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
